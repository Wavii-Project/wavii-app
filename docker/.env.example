# ─────────────────────────────────────────
# Wavii — Variables de entorno para Docker
# ─────────────────────────────────────────
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Pon tu IP local en HOST_IP (ver más abajo)
#   3. En producción, cambia TODOS los secretos

# ── Tu IP local en la red WiFi ──
# Necesaria para que Expo Go del móvil encuentre el Metro bundler
# En Windows: ipconfig → busca "Dirección IPv4" en tu adaptador WiFi
# En Mac/Linux: ifconfig | grep "inet "
# Ejemplo: 192.168.1.128
HOST_IP=192.168.1.128

# ── PostgreSQL ──
POSTGRES_DB=wavii
POSTGRES_USER=wavii
POSTGRES_PASSWORD=wavii_dev

# ── MongoDB ──
MONGO_USER=wavii
MONGO_PASSWORD=wavii_dev
MONGO_DB=wavii_docs

# ── JWT ──
# En producción, usar una cadena aleatoria de al menos 32 caracteres
# Genera una con: openssl rand -base64 32
JWT_SECRET=dev_secret_docker_change_in_production_32b

# ── App URL ──
APP_BASE_URL=https://undeduced-kaden-mentally.ngrok-free.dev
NEWSDATA_API_KEY=CHANGE_ME

# ── Gmail SMTP ──
MAIL_USERNAME=wavii.verificacion@gmail.com
MAIL_PASSWORD=kbjd suvi shmp vcfg
